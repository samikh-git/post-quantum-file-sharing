# Supabase (browser-safe anon key only)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Optional: public origin for Google OAuth return URL (must match Supabase redirect allow list).
# If unset, the browser’s current origin is used (fine for local dev and most prod deploys).
# VITE_SITE_URL=https://your-app.vercel.app

# Backend API origin (required for Vercel/production builds — set in host env and REDEPLOY).
# If unset locally, Vite proxies /me, /boxes, /files → localhost:3001.
# VITE_API_URL=http://localhost:3001
# VITE_API_URL=https://your-api.up.railway.app
